class ArcoLunarPainter extends CustomPainter {
  final double progreso;
  ArcoLunarPainter(this.progreso);
  @override
  void paint(Canvas canvas, Size size) {
    final paintFondo = Paint()
      ..color = Colors.white.withValues(alpha: 0.05)
      ..style = PaintingStyle.stroke
      ..strokeWidth = 2;
    Path path = Path();
    path.addArc(
      Rect.fromLTWH(0, 0, size.width, size.height * 2.5),
      math.pi,
      math.pi,
    );
    canvas.drawPath(path, paintFondo);
    if (progreso > 0 && progreso < 1) {
      double angulo = math.pi + (progreso * math.pi);
      double x = (size.width / 2) + (size.width / 2) * math.cos(angulo);
      double y = (size.height * 1.25) + (size.height * 1.25) * math.sin(angulo);
      canvas.drawCircle(Offset(x, y), 5, Paint()..color = Colors.white70);
    }
  }

  @override
  bool shouldRepaint(covariant CustomPainter oldDelegate) => true;
}

class SombraLunarPainter extends CustomPainter {
  final double fase;
  SombraLunarPainter(this.fase);
  @override
  void paint(Canvas canvas, Size size) {
    final paintSombra = Paint()
      ..color = Colors.black.withValues(alpha: 0.75)
      ..style = PaintingStyle.fill;
    final Rect rect = Offset.zero & size;
    final double centroX = size.width / 2;
    Path path = Path();
    double cosFase = math.cos(2 * math.pi * fase);
    double anchoSombra = (centroX * cosFase).abs();
    if (fase <= 0.5) {
      path.addArc(rect, math.pi / 2, math.pi);
      path.arcTo(
        Rect.fromLTRB(
          centroX - anchoSombra,
          0,
          centroX + anchoSombra,
          size.height,
        ),
        -math.pi / 2,
        cosFase > 0 ? math.pi : -math.pi,
        false,
      );
    } else {
      path.addArc(rect, -math.pi / 2, math.pi);
      path.arcTo(
        Rect.fromLTRB(
          centroX - anchoSombra,
          0,
          centroX + anchoSombra,
          size.height,
        ),
        math.pi / 2,
        cosFase > 0 ? math.pi : -math.pi,
        false,
      );
    }
    canvas.drawPath(path, paintSombra);
  }

  @override
  bool shouldRepaint(CustomPainter oldDelegate) => true;
}

Map<String, DateTime> calcularHorasSolares() {
  final ahora = DateTime.now();
  int diaDelAnio = int.parse(DateFormat("D").format(ahora));
  const double lat = 42.4833;
  const double lon = -5.9333;
  const double zenit = 90.833;

  double gamma = 2 * math.pi / 365 * (diaDelAnio - 1 + (ahora.hour - 12) / 24);
  double eqtime =
      229.18 *
      (0.000075 +
          0.001868 * math.cos(gamma) -
          0.032077 * math.sin(gamma) -
          0.014615 * math.cos(2 * gamma) -
          0.040849 * math.sin(2 * gamma));
  double decl =
      0.006918 -
      0.399912 * math.cos(gamma) +
      0.070257 * math.sin(gamma) -
      0.006758 * math.cos(2 * gamma) +
      0.000907 * math.sin(2 * gamma);

  double cosHa =
      (math.cos(zenit * math.pi / 180) /
          (math.cos(lat * math.pi / 180) * math.cos(decl))) -
      (math.tan(lat * math.pi / 180) * math.tan(decl));
  cosHa = cosHa.clamp(-1.0, 1.0);
  double ha = math.acos(cosHa) * 180 / math.pi;

  double sunriseUTC = 720 - 4 * (lon + ha) - eqtime;
  double sunsetUTC = 720 - 4 * (lon - ha) - eqtime;

  int offsetMinutos = ahora.timeZoneOffset.inMinutes;

  return {
    'amanecer': DateTime(
      ahora.year,
      ahora.month,
      ahora.day,
    ).add(Duration(minutes: sunriseUTC.toInt() + offsetMinutos)),
    'atardecer': DateTime(
      ahora.year,
      ahora.month,
      ahora.day,
    ).add(Duration(minutes: sunsetUTC.toInt() + offsetMinutos)),
  };
}

class PantallaInformacion extends StatelessWidget {
  const PantallaInformacion({super.key});

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      appBar: AppBar(
        centerTitle: true,
        title: const Text("Información"),
        backgroundColor: Colors.white,
        foregroundColor: Colors.black, // Texto negro
        elevation: 1,
      ),
      backgroundColor: Colors.white,
      body: StreamBuilder<DocumentSnapshot>(
        stream: FirebaseFirestore.instance
            .collection('app_config')
            .doc('informacion')
            .snapshots(),
        builder: (context, snapshot) {
          // 1. Estado de carga
          if (snapshot.connectionState == ConnectionState.waiting) {
            return const Center(child: CircularProgressIndicator());
          }

          // 2. Control de errores de conexión o permisos
          if (snapshot.hasError) {
            return Center(child: Text("Error de conexión: ${snapshot.error}"));
          }

          // 3. Verificar si el documento existe
          if (!snapshot.hasData || !snapshot.data!.exists) {
            return const Center(
              child: Text("El documento 'informacion' no existe en Firestore"),
            );
          }

          // 4. Extraer datos con seguridad
          final Map<String, dynamic> data =
              snapshot.data!.data() as Map<String, dynamic>;

          // Verificamos si existe el campo 'bloques'
          if (!data.containsKey('bloques')) {
            return const Center(
              child: Text("No se encontró el campo 'bloques' en el documento"),
            );
          }

          final List<dynamic> bloques = data['bloques'] ?? [];

          if (bloques.isEmpty) {
            return const Center(child: Text("La lista de bloques está vacía"));
          }

          // 5. Renderizar la lista
          return ListView.builder(
            padding: const EdgeInsets.all(20),
            itemCount: bloques.length,
            itemBuilder: (context, index) {
              final item = bloques[index];

              // Verificamos que sea un Mapa (como se ve en tus imágenes 350aff.png y 35835a.png)
              if (item is Map) {
                // Caso Texto: busca la clave 'texto'
                if (item.containsKey('texto')) {
                  return Padding(
                    padding: const EdgeInsets.only(bottom: 15),
                    child: Text(
                      item['texto'].toString(),
                      style: const TextStyle(
                        fontSize: 16,
                        color: Colors.black87,
                        height: 1.5,
                      ),
                    ),
                  );
                }

                // Caso Imagen: busca la clave 'imagen'
                if (item.containsKey('imagen')) {
                  return Padding(
                    padding: const EdgeInsets.only(bottom: 20),
                    child: ClipRRect(
                      borderRadius: BorderRadius.circular(15),
                      child: Image.network(
                        item['imagen'].toString(),
                        fit: BoxFit.cover,
                        errorBuilder: (context, error, stackTrace) =>
                            const Icon(
                              Icons.broken_image,
                              size: 50,
                              color: Colors.grey,
                            ),
                      ),
                    ),
                  );
                }
              }

              // Si el elemento no es un mapa reconocido, muestra el valor crudo para diagnóstico
              return Padding(
                padding: const EdgeInsets.all(8.0),
                child: Text("Dato no reconocido: $item"),
              );
            },
          );
        },
      ),
    );
  }
}
