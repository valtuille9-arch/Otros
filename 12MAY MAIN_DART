class SeccionSolar extends StatelessWidget {
  const SeccionSolar({super.key});

  @override
  Widget build(BuildContext context) {
    final ahora = DateTime.now();
    int diaDelAnio = int.parse(DateFormat("D").format(ahora));
    const double lat = 42.4833;
    const double lon = -5.9333;
    const double zenit = 90.833;

    double gamma =
        2 * math.pi / 365 * (diaDelAnio - 1 + (ahora.hour - 12) / 24);
    double eqtime =
        229.18 *
        (0.000075 +
            0.001868 * math.cos(gamma) -
            0.032077 * math.sin(gamma) -
            0.014615 * math.cos(2 * gamma) -
            0.040849 * math.sin(2 * gamma));
    double decl =
        0.006918 -
        0.399912 * math.cos(gamma) +
        0.070257 * math.sin(gamma) -
        0.006758 * math.cos(2 * gamma) +
        0.000907 * math.sin(2 * gamma);

    double cosHa =
        (math.cos(zenit * math.pi / 180) /
            (math.cos(lat * math.pi / 180) * math.cos(decl))) -
        (math.tan(lat * math.pi / 180) * math.tan(decl));

    cosHa = cosHa.clamp(-1.0, 1.0);
    double ha = math.acos(cosHa) * 180 / math.pi;

    double sunriseUTC = 720 - 4 * (lon + ha) - eqtime;
    double sunsetUTC = 720 - 4 * (lon - ha) - eqtime;

    int offsetMinutos = ahora.timeZoneOffset.inMinutes;
    final amanecer = DateTime(
      ahora.year,
      ahora.month,
      ahora.day,
    ).add(Duration(minutes: sunriseUTC.toInt() + offsetMinutos));
    final atardecer = DateTime(
      ahora.year,
      ahora.month,
      ahora.day,
    ).add(Duration(minutes: sunsetUTC.toInt() + offsetMinutos));

    double progreso = 0.0;
    if (ahora.isAfter(amanecer) && ahora.isBefore(atardecer)) {
      int total = atardecer.difference(amanecer).inMinutes;
      int transcurrido = ahora.difference(amanecer).inMinutes;
      progreso = transcurrido / total;
    } else if (ahora.isAfter(atardecer)) {
      progreso = 1.0;
    }

    return Container(
      margin: const EdgeInsets.symmetric(vertical: 10),
      padding: const EdgeInsets.all(20),
      decoration: BoxDecoration(
        color: Colors.white.withValues(alpha: 0.1),
        borderRadius: BorderRadius.circular(20),
      ),
      child: Column(
        children: [
          const Text(
            "Trayectoria Solar (San Román)",
            style: TextStyle(color: Colors.white70, fontSize: 14),
          ),
          const SizedBox(height: 30),
          SizedBox(
            height: 80,
            width: double.infinity,
            child: CustomPaint(painter: ArcoSolarPainter(progreso)),
          ),
          const SizedBox(height: 15),
          Row(
            mainAxisAlignment: MainAxisAlignment.spaceBetween,
            children: [
              _columnaDato("Salida", DateFormat('HH:mm').format(amanecer)),
              _columnaDato("Puesta", DateFormat('HH:mm').format(atardecer)),
            ],
          ),
        ],
      ),
    );
  }

  Widget _columnaDato(String titulo, String valor) {
    return Column(
      children: [
        Text(
          titulo,
          style: const TextStyle(color: Colors.white60, fontSize: 11),
        ),
        Text(
          valor,
          style: const TextStyle(
            color: Colors.white,
            fontWeight: FontWeight.bold,
            fontSize: 16,
          ),
        ),
      ],
    );
  }
}

class ArcoSolarPainter extends CustomPainter {
  final double progreso;
  ArcoSolarPainter(this.progreso);

  @override
  void paint(Canvas canvas, Size size) {
    final paintFondo = Paint()
      ..color = Colors.white.withValues(alpha: 0.1)
      ..style = PaintingStyle.stroke
      ..strokeWidth = 3;

    Path path = Path();
    path.addArc(
      Rect.fromLTWH(0, 0, size.width, size.height * 2),
      math.pi,
      math.pi,
    );
    canvas.drawPath(path, paintFondo);

    double angulo = math.pi + (progreso * math.pi);
    double x = (size.width / 2) + (size.width / 2) * math.cos(angulo);
    double y = (size.height) + (size.height) * math.sin(angulo);

    if (progreso > 0 && progreso < 1) {
      canvas.drawCircle(Offset(x, y), 8, Paint()..color = Colors.amber);
      canvas.drawCircle(
        Offset(x, y),
        12,
        Paint()..color = Colors.amber.withValues(alpha: 0.3),
      );
    }
  }

  @override
  bool shouldRepaint(covariant CustomPainter oldDelegate) => true;
}

class FichaLunarEstelar extends StatelessWidget {
  final String urlFondo;

  const FichaLunarEstelar({super.key, required this.urlFondo});

  Map<String, dynamic> calcularDatosLunares() {
    DateTime now = DateTime.now();
    DateTime refDate = DateTime.utc(2000, 1, 6, 18, 14);
    double synodicMonth = 29.530588853;
    double diff = now.toUtc().difference(refDate).inSeconds / 86400.0;
    double phase = (diff / synodicMonth) % 1.0;
    if (phase < 0) phase += 1.0;

    double edadLuna = phase * synodicMonth;
    double iluminacion = (1 - math.cos(2 * math.pi * phase)) / 2 * 100;

    double rad = (diff * 360 / 27.55455) * (math.pi / 180);
    double distanciaKm = 385000 - 20905 * math.cos(rad);
    String distanciaFormateada =
        "${NumberFormat('#,###', 'es_ES').format(distanciaKm)} Km";

    List<String> signos = [
      "Aries ♈", "Tauro ♉", "Géminis ♊", "Cáncer ♋", "Leo ♌", "Virgo ♍",
      "Libra ♎", "Escorpio ♏", "Sagitario ♐", "Capricornio ♑", "Acuario ♒", "Piscis ♓",
    ];
    int indexSigno = (((diff + 9.2) % 27.3216) / 2.276).floor() % 12;

    String nombreFase = "";
    if (edadLuna < 1.84) {
      nombreFase = "Luna Nueva";
    } else if (edadLuna < 5.53) {
      nombreFase = "Luna Creciente";
    } else if (edadLuna < 9.22) {
      nombreFase = "Cuarto Creciente";
    } else if (edadLuna < 12.91) {
      nombreFase = "Gibosa Creciente";
    } else if (edadLuna < 16.60) {
      nombreFase = "Luna Llena";
    } else if (edadLuna < 20.29) {
      nombreFase = "Gibosa Menguante";
    } else if (edadLuna < 23.98) {
      nombreFase = "Cuarto Menguante";
    } else if (edadLuna < 27.67) {
      nombreFase = "Luna Menguante";
    } else {
      nombreFase = "Luna Nueva";
    }

    return {
      'fase': nombreFase,
      'iluminacion': iluminacion.toStringAsFixed(1),
      'edad': edadLuna.toStringAsFixed(1),
      'distancia': distanciaFormateada,
      'signo': signos[indexSigno],
      'progreso': phase,
    };
  }

  @override
  Widget build(BuildContext context) {
    final datos = calcularDatosLunares();
    final phase = datos['progreso'] as double;
    final ahora = DateTime.now();

    int baseRiseMinutes = 424;
    int riseShift = (double.parse(datos['edad']) * 50.4).toInt();
    final salidaLuna = DateTime(ahora.year, ahora.month, ahora.day)
        .add(Duration(minutes: baseRiseMinutes + riseShift));
    final puestaLuna = salidaLuna.add(const Duration(hours: 12, minutes: 30));

    double progresoArco = 0.0;
    if (ahora.isAfter(salidaLuna) && ahora.isBefore(puestaLuna)) {
      int total = puestaLuna.difference(salidaLuna).inMinutes;
      int transcurrido = ahora.difference(salidaLuna).inMinutes;
      progresoArco = transcurrido / total;
    }

    final String urlFinal = urlFondo.isNotEmpty 
        ? urlFondo 
        : "https://www.solarsystemscope.com/textures/download/2k_stars_milky_way.jpg";

    return Container(
      margin: const EdgeInsets.symmetric(vertical: 15),
      decoration: BoxDecoration(
        borderRadius: BorderRadius.circular(30),
        color: Colors.white,
      ),
      child: ClipRRect(
        borderRadius: BorderRadius.circular(30),
        child: Stack(
          children: [
            Positioned.fill(
              child: CachedNetworkImage(
                imageUrl: urlFinal,
                fit: BoxFit.cover,
                errorWidget: (context, url, error) => Image.asset(
                  'assets/luna_fondo_default.jpg',
                  fit: BoxFit.cover,
                ),
              ),
            ),
            Positioned.fill(
              child: Container(color: Colors.black.withValues(alpha: 0.5)),
            ),
            Padding(
              padding: const EdgeInsets.all(25),
              child: Column(
                children: [
                  Row(
                    mainAxisAlignment: MainAxisAlignment.center,
                    children: [
                      const Icon(Icons.stars, color: Colors.white30, size: 18),
                      const SizedBox(width: 8),
                      Text(
                        datos['signo'],
                        style: const TextStyle(color: Colors.white, fontSize: 18, fontWeight: FontWeight.w300),
                      ),
                    ],
                  ),
                  const SizedBox(height: 20),
                  Stack(
                    alignment: Alignment.center,
                    children: [
                      SizedBox(
                        height: 100,
                        width: double.infinity,
                        child: CustomPaint(painter: ArcoLunarPainter(progresoArco)),
                      ),
                      Stack(
                        alignment: Alignment.center,
                        children: [
                          ClipOval(
                            child: Image.asset(
                              'assets/luna_real.png',
                              height: 120, width: 120, fit: BoxFit.cover,
                              errorBuilder: (context, error, stackTrace) => 
                                const Icon(Icons.nightlight_round, color: Colors.white24, size: 80),
                            ),
                          ),
                          CustomPaint(
                            size: const Size(120, 120),
                            painter: SombraLunarPainter(phase),
                          ),
                        ],
                      ),
                    ],
                  ),
                  const SizedBox(height: 15),
                  Text(
                    datos['fase'],
                    style: const TextStyle(color: Colors.white, fontSize: 24, fontWeight: FontWeight.bold),
                  ),
                  Text(
                    "Iluminación: ${datos['iluminacion']}%",
                    style: const TextStyle(color: Colors.white54, fontSize: 16),
                  ),
                  const Divider(color: Colors.white10, height: 40, thickness: 1),
                  Row(
                    mainAxisAlignment: MainAxisAlignment.spaceBetween,
                    children: [
                      _fichaDato("EDAD LUNAR", "${datos['edad']} d"),
                      _fichaDato("DISTANCIA", datos['distancia']),
                      _fichaDato("ESTADO", "Visible"),
                    ],
                  ),
                  const SizedBox(height: 20),
                  Row(
                    mainAxisAlignment: MainAxisAlignment.spaceAround,
                    children: [
                      _fichaDato("SALIDA LUNA", DateFormat('HH:mm').format(salidaLuna)),
                      _fichaDato("PUESTA LUNA", DateFormat('HH:mm').format(puestaLuna)),
