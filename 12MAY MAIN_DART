class ArcoLunarPainter extends CustomPainter {
  final double progreso;
  ArcoLunarPainter(this.progreso);

  @override
  void paint(Canvas canvas, Size size) {
    final paintFondo = Paint()
      ..color = Colors.white.withValues(alpha: 0.05)
      ..style = PaintingStyle.stroke
      ..strokeWidth = 2;

    Path path = Path();
    path.addArc(
      Rect.fromLTWH(0, 0, size.width, size.height * 2.5),
      math.pi,
      math.pi,
    );
    canvas.drawPath(path, paintFondo);

    if (progreso > 0 && progreso < 1) {
      double angulo = math.pi + (progreso * math.pi);
      double x = (size.width / 2) + (size.width / 2) * math.cos(angulo);
      double y = (size.height * 1.25) + (size.height * 1.25) * math.sin(angulo);
      canvas.drawCircle(Offset(x, y), 5, Paint()..color = Colors.white70);
    }
  }

  @override
  bool shouldRepaint(covariant CustomPainter oldDelegate) => true;
}

class SombraLunarPainter extends CustomPainter {
  final double fase;
  SombraLunarPainter(this.fase);

  @override
  void paint(Canvas canvas, Size size) {
    final paintSombra = Paint()
      ..color = Colors.black.withValues(alpha: 0.75)
      ..style = PaintingStyle.fill;

    final Rect rect = Offset.zero & size;
    final double centroX = size.width / 2;
    Path path = Path();
    double cosFase = math.cos(2 * math.pi * fase);
    double anchoSombra = (centroX * cosFase).abs();

    if (fase <= 0.5) {
      path.addArc(rect, math.pi / 2, math.pi);
      if (cosFase > 0) {
        path.arcTo(
          Rect.fromLTRB(
            centroX - anchoSombra,
            0,
            centroX + anchoSombra,
            size.height,
          ),
          -math.pi / 2,
          math.pi,
          false,
        );
      } else {
        path.arcTo(
          Rect.fromLTRB(
            centroX - anchoSombra,
            0,
            centroX + anchoSombra,
            size.height,
          ),
          -math.pi / 2,
          -math.pi,
          false,
        );
      }
    } else {
      path.addArc(rect, -math.pi / 2, math.pi);
      if (cosFase > 0) {
        path.arcTo(
          Rect.fromLTRB(
            centroX - anchoSombra,
            0,
            centroX + anchoSombra,
            size.height,
          ),
          math.pi / 2,
          math.pi,
          false,
        );
      } else {
        path.arcTo(
          Rect.fromLTRB(
            centroX - anchoSombra,
            0,
            centroX + anchoSombra,
            size.height,
          ),
          math.pi / 2,
          -math.pi,
          false,
        );
      }
    }
    canvas.drawPath(path, paintSombra);
  }

  @override
  bool shouldRepaint(CustomPainter oldDelegate) => true;
}
